#!/bin/sh
# Minimal Gradle wrapper stub generated by nimbus-tiers.
# For the full wrapper run: gradle wrapper --gradle-version 8.10
if ! command -v gradle >/dev/null 2>&1; then
  echo "[ERROR] 'gradle' not found on PATH. Install Gradle or generate the full wrapper:" >&2
  echo "  gradle wrapper --gradle-version 8.10" >&2
  exit 1
fi
exec gradle "$@"
