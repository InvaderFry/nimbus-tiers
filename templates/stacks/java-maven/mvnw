#!/bin/sh
# Minimal Maven wrapper stub generated by nimbus-tiers.
# For the full wrapper run: mvn wrapper:wrapper -Dmaven=3.9.9
if ! command -v mvn >/dev/null 2>&1; then
  echo "[ERROR] 'mvn' not found on PATH. Install Maven or generate the full wrapper:" >&2
  echo "  mvn wrapper:wrapper -Dmaven=3.9.9" >&2
  exit 1
fi
exec mvn "$@"
